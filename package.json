{
  "name": "grok-imagine-extension",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:content\"",
    "dev:vite": "vite",
    "dev:content": "node scripts/build-content.mjs --watch",
    "build": "vite build",
    "build:content": "node scripts/build-content.mjs",
    "build:all": "npm run build:content && npm run build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "vue": "^3.5.33"
  }
}
